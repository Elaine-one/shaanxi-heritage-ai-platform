# Agent服务环境变量配置文件
# 此文件包含所有必需的配置值，请根据实际情况填写

# 阿里云DashScope配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus-0806

# 天气API配置 - 使用Open-Meteo免费服务
WEATHER_API_KEY=
WEATHER_API_URL=https://api.open-meteo.com/v1

# 百度地图API配置
BAIDU_MAP_AK=your_baidu_map_ak_here
BAIDU_MAP_API_URL=https://api.map.baidu.com

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=heritage_db
DB_USER=root
DB_PASSWORD=your_database_password_here

# Django后端API配置
BACKEND_API_URL=http://localhost:8000/api

# Agent API CORS配置
AGENT_CORS_ALLOWED_ORIGINS=*

# 日志配置
LOG_LEVEL=WARNING
LOG_FILE=logs/agent.log

# 生产环境配置
DEVELOPMENT=false
DEBUG=false

# 旅游规划配置
TRAVEL_MAX_DAILY_ATTRACTIONS=4
TRAVEL_SPEED_KMH=90
TRAVEL_VISIT_DURATION_HOURS=6
TRAVEL_DAILY_START_TIME=09:00
TRAVEL_DAILY_END_TIME=21:00
TRAVEL_MAX_DISTANCE_KM=1000

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Session配置
SESSION_COOKIE_NAME=sessionid
SESSION_STORAGE_MODE=redis

# Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SESSION_TTL=86400

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=heritage-agent-storage
MINIO_SECURE=false
MINIO_REGION=us-east-1

# 归档配置
CONVERSATION_ARCHIVE_TTL=86400
PDF_RETENTION_DAYS=365
MEDIA_RETENTION_DAYS=90
AUTO_ARCHIVE_ENABLED=true

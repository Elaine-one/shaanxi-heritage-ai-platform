# =============================================================================
# Agent 服务环境变量配置
# =============================================================================
# 此文件为环境变量配置模板，复制为 .env 后填入实际值
# 参数详细说明请参见 Agent/config/settings.py 和 Agent/config/memory_budget.py

# ============================================================================
# LLM 配置 - 大语言模型
# ============================================================================
# 提供商: dashscope | zhipu | deepseek | openai | moonshot | ollama | custom
LLM_PROVIDER=dashscope

# API 密钥（必填）
LLM_API_KEY=your_api_key_here

# API 基础地址（可选，未设置时按 LLM_PROVIDER 自动选择）
LLM_BASE_URL=

# 模型名称（可选，未设置时按 LLM_PROVIDER 自动选择）
LLM_MODEL=qwen-plus

# 温度参数 (0.0-1.0)，值越低越确定性，默认 0.7
LLM_TEMPERATURE=0.7

# 最大输出 Token 数，0 表示由 memory_budget.output_budget_max 决定
LLM_MAX_TOKENS=4000

# ----------------------------------------------------------------------------
# 常用厂商配置参考
# ----------------------------------------------------------------------------
# 通义千问 (DashScope): LLM_PROVIDER=dashscope, LLM_MODEL=qwen-plus
# 智谱 GLM:           LLM_PROVIDER=zhipu, LLM_MODEL=glm-4
# DeepSeek:           LLM_PROVIDER=deepseek, LLM_MODEL=deepseek-chat
# OpenAI:              LLM_PROVIDER=openai, LLM_MODEL=gpt-4o

# ============================================================================
# 天气服务配置
# ============================================================================
# Open-Meteo 免费天气 API（无需 API 密钥）
WEATHER_API_KEY=
WEATHER_API_URL=https://api.open-meteo.com/v1

# ============================================================================
# 地图服务配置
# ============================================================================
# 高德地图 API Key（用于 REST API 和 MCP Server）
# 申请地址: https://console.amap.com/dev/key/app
AMAP_API_KEY=your_amap_api_key_here
AMAP_API_URL=https://restapi.amap.com/v3

# 高德 MCP Server URL（SSE 协议）
# MCP Server 使用同一个 AMAP_API_KEY
# 文档: https://www.modelscope.cn/mcp/servers/@amap/amap-maps
AMAP_MCP_URL=https://mcp.amap.com/sse

# 地图服务提供商: amap | baidu
MAP_PROVIDER=amap

# 百度地图配置（MAP_PROVIDER=baidu 时使用）
BAIDU_MAP_AK=
BAIDU_MAP_API_URL=https://api.map.baidu.com

# ============================================================================
# 数据库配置
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=heritage_db
DB_USER=root
DB_PASSWORD=your_database_password_here

# ============================================================================
# 后端 API 配置
# ============================================================================
BACKEND_API_URL=http://localhost:8000/api

# ============================================================================
# CORS 跨域配置
# ============================================================================
AGENT_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=WARNING
LOG_FILE=logs/agent.log

# ============================================================================
# 旅游规划参数
# ============================================================================
# 每日最大景点数
TRAVEL_MAX_DAILY_ATTRACTIONS=4
# 自驾速度 (km/h)
TRAVEL_SPEED_KMH=90
# 每次访问时长 (小时)
TRAVEL_VISIT_DURATION_HOURS=6
# 每日开始时间
TRAVEL_DAILY_START_TIME=09:00
# 每日结束时间
TRAVEL_DAILY_END_TIME=21:00
# 最大出行距离 (km)
TRAVEL_MAX_DISTANCE_KM=1000

# ============================================================================
# 缓存配置
# ============================================================================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ============================================================================
# Session 配置
# ============================================================================
SESSION_COOKIE_NAME=sessionid
# 存储模式: redis | memory
SESSION_STORAGE_MODE=redis

# ============================================================================
# Redis 配置
# ============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# 会话 TTL（秒），0 会导致 setex 异常，务必设置合理值
REDIS_SESSION_TTL=86400

# ============================================================================
# Neo4j 知识图谱配置（可选）
# ============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ============================================================================
# ChromaDB 向量数据库配置（可选）
# ============================================================================
CHROMADB_PERSIST_DIRECTORY=./data/chromadb
EMBEDDING_MODEL=BAAI/bge-small-zh

# ============================================================================
# MinIO 对象存储配置
# ============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=heritage-agent-storage
MINIO_SECURE=false
MINIO_REGION=us-east-1

# ============================================================================
# 数据归档配置
# ============================================================================
# 对话归档 TTL (秒)
CONVERSATION_ARCHIVE_TTL=86400
# 对话历史最大轮数（超过后裁剪最旧记录）
CONVERSATION_HISTORY_MAX_TURNS=20
# 对话压缩触发阈值（轮数达到此值时触发上下文压缩）
CONVERSATION_COMPRESS_THRESHOLD=15
# PDF 保留天数
PDF_RETENTION_DAYS=365
# 媒体文件保留天数
MEDIA_RETENTION_DAYS=90
# 自动归档启用
AUTO_ARCHIVE_ENABLED=true

# ============================================================================
# L1 摘要 LLM 配置（可选，不配置则复用主模型）
# ============================================================================
# 摘要模型名称，配置小模型可降低延迟和成本
# 示例: qwen-turbo, glm-4-flash, deepseek-chat
SUMMARY_LLM_MODEL=
# 摘要模型的 API Key，留空则复用 LLM_API_KEY
SUMMARY_LLM_API_KEY=
# 摘要模型的 API Base URL，留空则复用 LLM_BASE_URL
SUMMARY_LLM_BASE_URL=
# 摘要 LLM 调用超时（秒），超时后自动降级为规则摘要
SUMMARY_LLM_TIMEOUT=5
# 发送给摘要 LLM 的最大字符数
SUMMARY_LLM_MAX_CHARS=1200

# ============================================================================
# 数据同步配置
# ============================================================================
# 启动时同步非遗数据到知识图谱和向量数据库
# true: 每次启动检查并同步数据变化
# false: 跳过启动同步，加快启动速度（开发环境推荐）
HERITAGE_DATA_SYNC_ENABLED=true

# ============================================================================
# 并发控制配置
# ============================================================================
# 最大并发规划任务数
MAX_CONCURRENT_PLANNING=5
# 每用户最大并发规划任务数
MAX_PLANNING_PER_USER=2

# ============================================================================
# 资源清理配置
# ============================================================================
# 清理间隔 (秒)
CLEANUP_INTERVAL=300
# 会话最大存活时间 (小时)
SESSION_MAX_AGE_HOURS=12
# 进度缓存最大存活时间 (小时)
PROGRESS_MAX_AGE_HOURS=1

# ============================================================================
# 记忆与上下文预算配置
# ============================================================================
# 详细说明参见 Agent/config/memory_budget.py
# 所有参数均可通过环境变量覆盖，以下为默认值

# 模型上下文窗口大小（tokens），切换模型时务必同步修改
# qwen-plus=131072, glm-4=128000, gpt-4o=128000,
# deepseek-chat=128000, moonshot-v1-8k=8192
MODEL_CONTEXT_WINDOW=128000

# 输入预算（tokens），控制发送给 LLM 的 prompt 总大小
# 30K 分配建议: system≈2000, conversation≈18000 (60%),
#              working_memory≈1800, RAG+KGL≈3000, 其余≈5200
INPUT_BUDGET=30000
# 输入预算下限，低于此值时强制提升
INPUT_BUDGET_MIN=3000
# 输入预算上限，动态预算计算结果不会超过此值
# 重度规划场景需要更多上下文，120K模型窗口充裕
INPUT_BUDGET_MAX=45000

# 输出预算（tokens），由 _determine_output_budget 按意图动态调整
# 短问答/闲聊≈4K, 一般规划≈6K, 复杂路线≈10K
OUTPUT_BUDGET_DEFAULT=6000
OUTPUT_BUDGET_MIN=400
OUTPUT_BUDGET_MAX=10000

# 上下文压缩器的 token 预算，应小于 INPUT_BUDGET
CONTEXT_COMPRESSION_BUDGET=15000

# RAG 向量检索参数
RAG_TOP_K_MIN=1
RAG_TOP_K_MAX=5
# RAG 注入上下文时的单次最大字符数
RAG_CONTEXT_MAX_CHARS=1800

# 工具返回结果的最大字符数（超出截断）
TOOL_RESULT_MAX_CHARS=2000

# L1 滚动窗口参数（Redis 感知层）
# 最近对话保留轮数，超出后触发滚动丢弃
MEMORY_L1_RECENT_LIMIT=20
# 每次滚动丢弃的最旧轮数
MEMORY_L1_ROLLING_DROP_COUNT=2
# session_summary 增量摘要合并后的最大字符数
MEMORY_L1_SUMMARY_MAX_CHARS=800
# 单轮对话摘要的最大字符数
MEMORY_L1_TURN_SUMMARY_MAX_CHARS=120

# L2/L3/Sifter 开关
# L2 图记忆（Neo4j），Neo4j 不可用时自动禁用
GRAPH_MEMORY_ENABLED=true
# L3 审计账本（SQLite）
L3_LEDGER_ENABLED=true
# Sifter 对话沉淀筛选器
SIFTER_ENABLED=true

# Sifter 关键词（逗号分隔），触发长期记忆沉淀的热词
MEMORY_SIFTER_KEYWORDS=预算,自驾,公交,步行,高铁,西安,咸阳,宝鸡,喜欢,偏好
# Sifter 默认置信度（整数除以100，如45→0.45），用于强信号偏好
MEMORY_SIFTER_CONFIDENCE=45
# Sifter 低置信度（整数除以100，如35→0.35），用于弱信号偏好
MEMORY_SIFTER_CONFIDENCE_LOW=35
# Sifter 提取的偏好值最大字符数
MEMORY_SIFTER_PREF_VALUE_MAX_CHARS=40

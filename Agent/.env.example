# =============================================================================
# Agent 服务环境变量配置
# =============================================================================
# 此文件为环境变量配置模板，复制为 .env 后填入实际值

# ============================================================================
# LLM 配置 - 大语言模型
# ============================================================================
# 提供商: dashscope | zhipu | deepseek | openai | moonshot | ollama | custom
LLM_PROVIDER=dashscope

# API 密钥（必填）
LLM_API_KEY=your_api_key_here

# API 基础地址（可选，自定义提供商时必填）
LLM_BASE_URL=

# 模型名称
LLM_MODEL=qwen-plus

# 温度参数 (0.0-1.0)，值越低越确定性
LLM_TEMPERATURE=0.7

# 最大输出 Token 数
LLM_MAX_TOKENS=4000

# ----------------------------------------------------------------------------
# 常用厂商配置参考
# ----------------------------------------------------------------------------
# 通义千问 (DashScope): LLM_PROVIDER=dashscope, LLM_MODEL=qwen-plus
# 智谱 GLM:           LLM_PROVIDER=zhipu, LLM_MODEL=glm-4
# DeepSeek:           LLM_PROVIDER=deepseek, LLM_MODEL=deepseek-chat
# OpenAI:              LLM_PROVIDER=openai, LLM_MODEL=gpt-4o

# ============================================================================
# 天气服务配置
# ============================================================================
# Open-Meteo 免费天气 API（无需 API 密钥）
WEATHER_API_KEY=
WEATHER_API_URL=https://api.open-meteo.com/v1

# ============================================================================
# 地图服务配置
# ============================================================================
# 高德地图 API（用于路线规划）
AMAP_API_KEY=your_amap_api_key_here
AMAP_API_URL=https://restapi.amap.com/v3

# 地图服务提供商: amap | baidu
MAP_PROVIDER=amap

# ============================================================================
# 数据库配置
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=heritage_db
DB_USER=root
DB_PASSWORD=your_database_password_here

# ============================================================================
# 后端 API 配置
# ============================================================================
BACKEND_API_URL=http://localhost:8000/api

# ============================================================================
# CORS 跨域配置
# ============================================================================
AGENT_CORS_ALLOWED_ORIGINS=*

# ============================================================================
# 日志配置
# ============================================================================
LOG_LEVEL=WARNING
LOG_FILE=logs/agent.log

# ============================================================================
# 服务模式配置
# ============================================================================
# 生产环境设为 true
DEVELOPMENT=false
DEBUG=false

# ============================================================================
# 旅游规划参数
# ============================================================================
# 每日最大景点数
TRAVEL_MAX_DAILY_ATTRACTIONS=4
# 自驾速度 (km/h)
TRAVEL_SPEED_KMH=90
# 每次访问时长 (小时)
TRAVEL_VISIT_DURATION_HOURS=6
# 每日开始时间
TRAVEL_DAILY_START_TIME=09:00
# 每日结束时间
TRAVEL_DAILY_END_TIME=21:00
# 最大出行距离 (km)
TRAVEL_MAX_DISTANCE_KM=1000

# ============================================================================
# 缓存配置
# ============================================================================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ============================================================================
# Session 配置
# ============================================================================
SESSION_COOKIE_NAME=sessionid
SESSION_STORAGE_MODE=redis

# ============================================================================
# Redis 配置
# ============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SESSION_TTL=86400

# ============================================================================
# Neo4j 知识图谱配置（可选）
# ============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ============================================================================
# ChromaDB 向量数据库配置（可选）
# ============================================================================
CHROMADB_PERSIST_DIRECTORY=./data/chromadb
EMBEDDING_MODEL=BAAI/bge-small-zh
LOCAL_MODEL_PATH=./data/models/bge-small-zh

# ============================================================================
# MinIO 对象存储配置
# ============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=heritage-agent-storage
MINIO_SECURE=false
MINIO_REGION=us-east-1

# ============================================================================
# 数据归档配置
# ============================================================================
# 对话归档 TTL (秒)
CONVERSATION_ARCHIVE_TTL=86400
# PDF 保留天数
PDF_RETENTION_DAYS=365
# 媒体文件保留天数
MEDIA_RETENTION_DAYS=90
# 自动归档启用
AUTO_ARCHIVE_ENABLED=true

# ============================================================================
# 数据同步配置
# ============================================================================
# 启动时同步非遗数据到知识图谱和向量数据库
# true: 每次启动检查并同步数据变化
# false: 跳过启动同步，加快启动速度（开发环境推荐）
HERITAGE_DATA_SYNC_ENABLED=true

# ============================================================================
# 并发控制配置
# ============================================================================
# 最大并发规划任务数
MAX_CONCURRENT_PLANNING=5
# 每用户最大并发规划任务数
MAX_PLANNING_PER_USER=2

# ============================================================================
# 资源清理配置
# ============================================================================
# 清理间隔 (秒)
CLEANUP_INTERVAL=300
# 会话最大存活时间 (小时)
SESSION_MAX_AGE_HOURS=12
# 进度缓存最大存活时间 (小时)
PROGRESS_MAX_AGE_HOURS=1

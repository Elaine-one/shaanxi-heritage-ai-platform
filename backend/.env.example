# =============================================================================
# Django 后端服务环境变量配置
# =============================================================================
# 此文件为环境变量配置模板，复制为 .env 后填入实际值

# ============================================================================
# Django 核心配置
# ============================================================================
# Django 密钥（必填，请使用随机字符串）
DJANGO_SECRET_KEY=your_django_secret_key_here

# 调试模式（生产环境设为 False）
DEBUG=True

# ============================================================================
# 主机和跨域配置
# ============================================================================
# 允许的主机列表，逗号分隔
ALLOWED_HOSTS=localhost,127.0.0.1

# 允许跨域的来源列表，逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# CSRF 信任的来源列表，逗号分隔
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 是否允许所有来源跨域（开发环境设为 True）
CORS_ALLOW_ALL_ORIGINS=True

# ============================================================================
# 数据库配置
# ============================================================================
DB_NAME=heritage_db
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_HOST=localhost
DB_PORT=3306

# ============================================================================
# Redis 配置
# ============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# 百度地图 API
# ============================================================================
BAIDU_MAP_AK=your_baidu_map_ak_here

# ============================================================================
# 邮件服务配置
# ============================================================================
EMAIL_HOST=smtp.163.com
EMAIL_PORT=465
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@163.com
EMAIL_HOST_PASSWORD=your_email_auth_code_here
DEFAULT_FROM_EMAIL=your_email@163.com

# ============================================================================
# 前端应用地址
# ============================================================================
FRONTEND_URL=http://localhost:8080

# ============================================================================
# Agent 服务配置
# ============================================================================
AGENT_SERVICE_URL=http://localhost:8001
